# See dunst(5) for all configuration options

[global]
    follow = keyboard

    ### Progress bar ###

    progress_bar = true # e.g. dunstify -h int:value:12 (or notify-send)
    progress_bar_height = 10  # Must be at least 2xframe_width
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    # Appearance
    scale = 0

    width = (300, 600)  # Min, Max
    height = 500        # Max
    origin = top-right
    offset = 20x55      # horizontal x vertical # padding x (xmobar-height + padding)

    transparency = 10

    padding = 10     # Vertical
    horizontal_padding = 10
    text_icon_padding = 10

    frame_width = 3     # pixels
    frame_color = "#aaaaaa"

    corner_radius = 0

    # Multiple
    notification_limit = 4
    indicate_hidden = yes

    gap_size = 0    # Needs compositor. If >0, separator_height is ignored
    separator_height = 4 # Pixels. Line between notifications
    separator_color = auto     # auto | foreground | frame | X color

    sort = yes # By urgency

    idle_threshold = 120 # Don't remove if user has been idle for >= seconds


    ### Text ###

    font = Monospace 14
    # line_height = 5   # FIXME: Not sure how to make this work

    markup = full   # full | strip | no

    # The format of the message.  Possible variables are:
    #   %a  appname
    #   %s  summary
    #   %b  body
    #   %i  iconname (including its path)
    #   %I  iconname (without its path)
    #   %p  progress value if set ([  0%] to [100%]) or nothing
    #   %n  progress value if set without any extra characters
    #   %%  Literal %
    # Markup is allowed
    format = "<b>[%a] %s</b> %p\n%b"

    alignment = left    # left | center | right
    vertical_alignment = center # top | center | bottom

    show_age_threshold = 30     # Seconds after which to show age

    ellipsize = middle  # start | middle | end
    ignore_newline = no

    stack_duplicates = true
    hide_duplicate_count = false

    show_indicators = yes # (U) or (A) prepended when there are urls or actions

    ### Icons ###

    # enable_recursive_icon_lookup = true # Need to set icon_path otherwise
    icon_theme = Adwaita, hicolor
    icon_position = left

    min_icon_size = 32
    max_icon_size = 128

    ### History ###

    sticky_history = yes
    history_length = 20

    ### Misc/Advanced ###

    dmenu = /usr/bin/rofi -dmenu
    browser = /usr/bin/xdg-open

    # | none
    # | do_action | open_url
    # | close_current | close_all
    # | context | context_all
    mouse_left_click = do_action, open_url, close_current
    mouse_middle_click = close_all
    mouse_right_click = close_current

[urgency_low]
    background = "#222222"
    foreground = "#888888"
    timeout = 10

[urgency_normal]
    background = "#285577"
    foreground = "#ffffff"
    timeout = 10
    default_icon = "emblem-new"

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 0
    default_icon = "emblem-important"



# Every section that isn't one of the above is interpreted as a rules to
# override settings for certain messages.
#
# Messages can be matched by
#    body
#    category
#    desktop_entry
#    icon
#    match_transient
#    msg_urgency
#    stack_tag
#    summary
#
# and you can override the
#    background
#    foreground
#    format
#    frame_color
#    fullscreen
#    new_icon
#    set_stack_tag
#    set_transient
#    set_category
#    timeout
#    urgency
#    icon_position
#    skip_display
#    history_ignore
#    action_name
#    word_wrap
#    ellipsize
#    alignment
#    hide_text
#
# Shell-like globbing will get expanded.
#
# script = something.sh
# > script appname summary body icon urgency
# where urgency can be "LOW", "NORMAL" or "CRITICAL".

[fullscreen_delay_everything]
   fullscreen = pushback   # show | delay | pushback
[fullscreen_show_critical]
   msg_urgency = critical
   fullscreen = show

# See examples in /etc/xdg/dunst/dunstrc

# vim: ft=cfg
